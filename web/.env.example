# Modèle — COPIER vers web/.env.local et remplir avec la config du projet Firebase
# (Firebase console > Paramètres du projet > Vos applications > SDK Web).
# web/.env.local est gitignored et ne doit JAMAIS être commité.
# Ces valeurs sont des identifiants PUBLICS côté client (pas des secrets serveur) :
# la sécurité repose sur les règles Firestore + le verrou de domaine, pas sur leur secret.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- SECRETS SERVEUR (routes API nodejs) -------------------------------------
# ⚠️ VRAIS secrets (PAS de préfixe NEXT_PUBLIC_ : jamais exposés au client).
# Définis sur Vercel (Project Settings > Environment Variables), jamais commités.
# Les creds Admin SDK et DENDREO_WEBHOOK_SECRET du webhook vivent aussi sur Vercel.

# Jeton bas-privilège de la route de lecture GET /api/export/sheet (automatisation
# Google Sheets, S10.1). Lecture seule, révocable en changeant cette valeur.
SHEET_EXPORT_TOKEN=
